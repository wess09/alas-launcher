{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AzurPilot",
  "version": "1.6.6",
  "identifier": "moe.taiho.alas-launcher",
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AzurPilot",
        "width": 1280,
        "height": 880,
        "resizable": true,
        "url": "about:blank",
        "acceptFirstMouse": true,
        "visible": false,
        "create": false
      },
      {
        "label": "splash",
        "title": "AzurPilot",
        "width": 620,
        "height": 280,
        "resizable": false,
        "url": "about:blank",
        "acceptFirstMouse": true,
        "visible": true,
        "create": true
      }
    ]
  }
}
