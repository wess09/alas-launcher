{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AzurPilot",
  "version": "2.1.4",
  "identifier": "moe.taiho.alas-launcher",
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AzurPilot",
        "width": 1280,
        "height": 880,
        "resizable": true,
        "additionalBrowserArgs": "--enable-features=msWebView2EnableDraggableRegions --disable-features=ElasticOverscroll,msWebOOUI,msPdfOOUI,msSmartScreenProtection",
        "url": "about:blank",
        "acceptFirstMouse": true,
        "visible": false,
        "create": false
      },
      {
        "label": "splash",
        "title": "AzurPilot",
        "width": 800,
        "height": 450,
        "resizable": false,
        "decorations": false,
        "additionalBrowserArgs": "--enable-features=msWebView2EnableDraggableRegions --disable-features=ElasticOverscroll,msWebOOUI,msPdfOOUI,msSmartScreenProtection",
        "url": "about:blank",
        "acceptFirstMouse": true,
        "visible": false,
        "create": true
      }
    ]
  }
}
